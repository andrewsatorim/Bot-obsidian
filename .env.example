# Bot-Obsidian Configuration
# Copy to .env and fill in your values

# Core (OKX perpetual format: BASE/QUOTE:SETTLE)
BOT_SYMBOL=BTC/USDT:USDT
BOT_SCAN_INTERVAL_SEC=10.0
BOT_COOLDOWN_SEC=60.0

# Risk
BOT_MAX_POSITION_PCT=0.02
BOT_MAX_DAILY_LOSS_PCT=0.05
BOT_ATR_RISK_MULTIPLIER=1.5
BOT_MAX_OPEN_POSITIONS=3
BOT_ACCOUNT_EQUITY=10000.0

# Exchange (okx for OKX)
BOT_EXCHANGE_ID=okx
BOT_EXCHANGE_API_KEY=
BOT_EXCHANGE_API_SECRET=
BOT_EXCHANGE_PASSPHRASE=  # Required for OKX
BOT_PAPER_TRADING=true

# Telegram
BOT_TELEGRAM_BOT_TOKEN=
BOT_TELEGRAM_CHAT_ID=

# Storage
BOT_STORAGE_PATH=data/bot_state.db

# Logging
BOT_LOG_LEVEL=INFO
